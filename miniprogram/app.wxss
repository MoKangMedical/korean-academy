page {
  min-height: 100vh;
  background: #09090B;
  color: #FAFAFA;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero {
  padding: 40rpx 0 24rpx;
}

.eyebrow {
  color: #71717A;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.title {
  margin-top: 12rpx;
  color: #F5D98E;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 10rpx;
  color: #A1A1AA;
  font-size: 28rpx;
}

.section-title {
  margin: 32rpx 0 18rpx;
  color: #FAFAFA;
  font-size: 32rpx;
  font-weight: 650;
}

.card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #27272A;
  border-radius: 16rpx;
  background: #18181B;
  box-sizing: border-box;
}

.gold-card {
  border-color: rgba(226, 182, 79, 0.35);
  background: linear-gradient(135deg, rgba(226, 182, 79, 0.12), rgba(226, 182, 79, 0.03));
}

.row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.grow {
  flex: 1;
  min-width: 0;
}

.card-title {
  color: #FAFAFA;
  font-size: 31rpx;
  font-weight: 650;
}

.card-subtitle {
  margin-top: 8rpx;
  color: #A1A1AA;
  font-size: 24rpx;
  line-height: 1.45;
}

.meta {
  margin-top: 8rpx;
  color: #71717A;
  font-size: 22rpx;
}

.badge {
  min-width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: rgba(226, 182, 79, 0.14);
  color: #E2B64F;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.arrow {
  color: #71717A;
  font-size: 42rpx;
}

.button {
  height: 84rpx;
  border-radius: 14rpx;
  background: #E2B64F;
  color: #09090B;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.button.secondary {
  border: 1rpx solid rgba(226, 182, 79, 0.35);
  background: transparent;
  color: #E2B64F;
}

.empty {
  padding: 48rpx 20rpx;
  color: #71717A;
  text-align: center;
  font-size: 26rpx;
}

.korean {
  color: #E2B64F;
  font-family: "Apple SD Gothic Neo", sans-serif;
  font-weight: 700;
}
