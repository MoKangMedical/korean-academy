<view class="page">
  <view class="card gold-card">
    <view class="card-title">{{lesson.title || title}}</view>
    <view class="card-subtitle">本课讲解音频已预生成，适合跟读和复习</view>
    <view class="button" bindtap="toggleAudio">{{playing ? '暂停课程音频' : '播放课程音频'}}</view>
    <view class="button secondary complete-button" bindtap="markComplete">标记完成并记录进步</view>
  </view>

  <view class="card">
    <view class="card-title">课程内容</view>
    <view class="lesson-content">{{plainContent}}</view>
  </view>

  <view class="section-title">本课词汇</view>
  <block wx:if="{{vocab.length}}">
    <view class="card row" wx:for="{{vocab}}" wx:key="id" bindtap="goVoice" data-korean="{{item.korean}}" data-sentence="{{item.example_ko || item.korean}}">
      <view class="badge">音</view>
      <view class="grow">
        <view class="card-title korean">{{item.korean}}</view>
        <view class="card-subtitle">{{item.romanization}} · {{item.chinese}}</view>
      </view>
      <view class="arrow">›</view>
    </view>
  </block>
  <view wx:else class="empty">暂无词汇</view>
</view>
