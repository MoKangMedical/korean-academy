<view class="page">
  <view class="card gold-card">
    <view class="profile-avatar">K</view>
    <view class="profile-name">{{user.nickname || '韩语学习者'}}</view>
    <view class="card-subtitle">Level {{user.level || 1}} · XP {{user.xp || 0}}</view>
  </view>

  <view class="section-title">学习状态</view>
  <view class="card row">
    <view class="badge">课</view>
    <view class="grow">
      <view class="card-title">{{progress.completed_lessons || 0}} / {{progress.total_lessons || 0}}</view>
      <view class="card-subtitle">课程进度</view>
    </view>
  </view>
  <view class="card row">
    <view class="badge">词</view>
    <view class="grow">
      <view class="card-title">{{progress.total_vocabulary || 0}}</view>
      <view class="card-subtitle">词汇量</view>
    </view>
  </view>

  <view class="section-title">音频标准</view>
  <view class="card">
    <view class="card-title">24kHz · mono · 48kbps</view>
    <view class="card-subtitle">课程音频和发音录音统一规格</view>
  </view>
</view>
